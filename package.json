{
  "name": "pokedex",
  "type": "module",
  "homepage": "https://shady356.github.io/pokedex/",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "serve": "vite",
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "lint": "eslint --ext .js,.vue src"
  },
  "dependencies": {
    "@tanstack/vue-query": "^5.100.10",
    "axios": "^0.30.0",
    "chart.js": "^4.5.1",
    "gh-pages": "^3.2.3",
    "gsap": "^3.6.0",
    "lodash.sortby": "^4.7.0",
    "material-icons": "^1.13.14",
    "sass": "^1.69.0",
    "vue": "^3.5.34",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "eslint": "^7.32.0",
    "eslint-plugin-vue": "^7.0.0",
    "vite": "^5.0.0",
    "vite-plugin-pwa": "^0.20.0"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:vue/recommended",
      "eslint:recommended"
    ],
    "parserOptions": {
      "ecmaVersion": 2020
    },
    "rules": {
      "vue/no-confusing-v-for-v-if": "error",
      "vue/this-in-template": "error",
      "vue/eqeqeq": "error"
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions"
  ]
}
